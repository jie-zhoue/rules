# if connect to services.googleapis.cn directly,
# then these domains will be used.
# 北京 (2x3)、上海 (ni5)、广州 (j5o)
URL-REGEX,^https?://r+[0-9]+(---|\.)sn-(2x3|ni5|j5o)[A-Za-z0-9_]{5}\.xn--ngstr-lra8j\.com(/.*)?$ # @cn
# the same but DNS pollution in China mainland.
URL-REGEX,^https?://r+[0-9]+(---|\.)sn-(2x3|ni5|j5o)[A-Za-z0-9_]{5}\.googlevideo\.com(/.*)?$ # @cn

